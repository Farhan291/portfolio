---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Homecontent from "@/content/pages/Home.md";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
const posts = await getCollection("blog");
const latestPosts = posts
    .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate))
    .slice(0, 6);
---

<Layout
    title="Home | farhan"
    description="Farhan's personal blog — writing about Linux, systems programming, networking, and self-hosting."
    type="website"
    jsonLd={{
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "farhan",
        url: "https://ifarhan.tech",
        description: "Farhan's personal blog — writing about Linux, systems programming, networking, and self-hosting.",
        author: {
            "@type": "Person",
            name: "Farhan",
            url: "https://ifarhan.tech/about",
        },
    }}
>
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold tracking-tight pl-1 pb-3">Latest writing</h2>

            <a
                href="/blog"
                class="text-sm text-muted-foreground hover:text-foreground transition pb-3"
            >
                View all →
            </a>
        </div>

        <div class="space-y-4">
            {
                latestPosts.map((post) => (
                    <a
                        href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}
                        class="block rounded-lg border border-border p-4 hover:bg-accent transition"
                    >
                        <div class="flex justify-between items-start gap-4">
                            <div>
                                <p class="font-medium">{post.data.title}</p>
                                <p class="text-sm text-muted-foreground mt-1">
                                    {post.data.description}
                                </p>
                            </div>

                            <time class="text-xs text-muted-foreground whitespace-nowrap">
                                {new Date(
                                    post.data.pubDate,
                                ).toLocaleDateString()}
                            </time>
                        </div>
                    </a>
                ))
            }
        </div>
    <p class="mt-8 text-sm text-muted-foreground">
        <a
            href="https://farhan291.github.io/profile/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-foreground transition-colors opacity-70 hover:opacity-100"
        >
            view the previous/archived version →
        </a>
    </p>
</Layout>
