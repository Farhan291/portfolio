---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const posts = await getCollection("blog");
const latestPosts = posts
    .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate))
    .slice(0, 5);

const projects = [
    {
        title: "Fetchy",
        details:
            "Minimal, curl-like CLI utility written in C for fetching web content over HTTP/HTTPS.",
        tags: ["C", "POSIX", "UNIX", "OpenSSL", "Sockets"],
        url: "https://github.com/Farhan291/fetchy",
    },
    {
        title: "Ember",
        details:
            "HTTP server written in C from scratch using only standard POSIX APIs.",
        tags: ["C", "POSIX", "HTTP"],
        url: "https://github.com/Farhan291/Ember",
    },
    {
        title: "create-light-stack",
        details:
            "Minimal, opinionated CLI to scaffold a full-stack monorepo without the headache.",
        tags: ["TypeScript", "Next.js", "Hono", "Drizzle"],
        url: "https://github.com/Farhan291/create-light-stack",
    },
    {
        title: "Hyprwatch",
        details:
            "Lightweight time tracking daemon and TUI client for the Hyprland window manager. Tracks time spent per application via Hyprland IPC with an ncurses-based interface.",
        tags: ["C", "Hyprland", "ncurses", "IPC", "Linux"],
        url: "https://github.com/Farhan291/hyprwatch",
    },
];

const socials = [
    {
        label: "GitHub",
        handle: "@farhan291",
        url: "https://github.com/Farhan291",
    },
    {
        label: "Twitter",
        handle: "@mkdir_autisim",
        url: "https://x.com/mkdir_autisim",
    },
    { label: "Telegram", handle: "@light592", url: "https://t.me/light592" },
    {
        label: "Matrix",
        handle: "@lightchan:matrix.org",
        url: "https://matrix.to/#/@lightchan:matrix.org",
    },
    {
        label: "Email",
        handle: "hello@ifarhan.tech",
        url: "mailto:hello@ifarhan.tech",
    },
];

const communities = [
    { label: "r/btechtards", url: "https://www.reddit.com/r/Btechtards/" },
    {
        label: "r/LinuxUsersIndia",
        url: "https://www.reddit.com/r/LinuxUsersIndia/",
    },
];
---

<Layout
    title="Home | farhan"
    description="Farhan's personal blog — writing about Linux, systems programming, networking, and self-hosting."
    type="website"
    jsonLd={{
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Farhan",
        url: "https://ifarhan.tech",
        description:
            "Farhan's personal blog — writing about Linux, systems programming, networking, and self-hosting.",
        sameAs: ["https://github.com/farhan291"],
        jobTitle: "CS Student",
        affiliation: "RIT Bangalore",
    }}
>
    <!-- Hero -->
    <section class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-8 mb-10">
        <!-- Left sidebar -->
        <div
            class="flex flex-row md:flex-col items-center md:items-start gap-4 md:gap-3"
        >
            <Image
                src="https://github.com/farhan291.png"
                alt="Farhan"
                class="size-20 md:size-32 rounded-xl object-cover shrink-0"
                width={256}
                height={256}
                quality={100}
            />
            <div>
                <h1 class="text-lg font-bold tracking-tight">farhan</h1>
                <p class="text-xs text-muted-foreground mt-0.5">
                    systems programmer
                </p>
                <!-- social icons -->
                <div class="flex items-center gap-2 mt-3">
                    <a
                        href="https://github.com/Farhan291"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-muted-foreground hover:text-foreground transition-colors"
                        title="GitHub"
                    >
                        <svg
                            class="size-4"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="mailto:hello@ifarhan.tech"
                        class="text-muted-foreground hover:text-foreground transition-colors"
                        title="Email"
                    >
                        <svg
                            class="size-4"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect width="20" height="16" x="2" y="4" rx="2"
                            ></rect>
                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://x.com/mkdir_autisim"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-muted-foreground hover:text-foreground transition-colors"
                        title="Twitter"
                    >
                        <svg
                            class="size-4"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.727-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://t.me/light592"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-muted-foreground hover:text-foreground transition-colors"
                        title="Telegram"
                    >
                        <svg
                            class="size-4"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.7 8.02c-.12.56-.46.7-.93.43l-2.57-1.89-1.24 1.19c-.14.14-.25.25-.51.25l.18-2.6 4.72-4.26c.2-.18-.05-.28-.32-.1L7.9 14.49l-2.53-.79c-.55-.17-.56-.55.12-.82l9.89-3.81c.46-.17.86.11.26.73z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="/rss.xml"
                        class="text-muted-foreground hover:text-foreground transition-colors"
                        title="RSS"
                    >
                        <svg
                            class="size-4"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"
                            ></path>
                        </svg>
                    </a>
                </div>
                <p
                    class="text-xs text-muted-foreground mt-3 flex items-center gap-1"
                >
                    <svg
                        class="size-3"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                        ></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                    Bangalore, India
                </p>
            </div>
        </div>

        <!-- Right: About Me -->
        <div>
            <h2 class="text-xl font-bold tracking-tight mb-1">About Me</h2>
            <div
                class="w-10 h-0.5 bg-gradient-to-r from-violet-500 to-pink-500 rounded mb-5"
            >
            </div>
            <div
                class="space-y-3 text-sm text-muted-foreground leading-relaxed"
            >
                <p>
                    I'm a CS undergrad at <span
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300 text-xs font-medium"
                        >RIT Bangalore</span
                    >, mostly into systems programming — building things close
                    to the metal in <span
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300 text-xs font-medium"
                        >C</span
                    > and <span
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 dark:bg-amber-950 dark:text-amber-300 text-xs font-medium"
                        >Linux</span
                    >. I'm into kernels, networking, and virtualization. Most of
                    my projects are things I built while trying to understand
                    how something works under the hood.
                </p>
                <p>
                    I've been active in <span
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-violet-100 text-violet-700 dark:bg-violet-950 dark:text-violet-300 text-xs font-medium"
                        >STEM</span
                    > communities since high school and currently moderate <a
                        href="https://reddit.com/r/Btechtards"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-orange-100 text-orange-700 dark:bg-orange-950 dark:text-orange-300 text-xs font-medium hover:opacity-80 transition-opacity"
                        >r/btechtards</a
                    > and <a
                        href="https://reddit.com/r/LinuxUsersIndia"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 dark:bg-amber-950 dark:text-amber-300 text-xs font-medium hover:opacity-80 transition-opacity"
                        >r/LinuxUsersIndia</a
                    >. Always open to conversations and collaborations — reach
                    me at <a
                        href="mailto:hello@ifarhan.tech"
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300 text-xs font-medium hover:opacity-80 transition-opacity"
                        >hello@ifarhan.tech</a
                    >.
                </p>
                <p>
                    I write about whatever I'm currently digging into. If you
                    want, you can also subscribe via  <a
                        href="/rss.xml"
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-orange-100 text-orange-700 dark:bg-orange-950 dark:text-orange-300 text-xs font-medium hover:opacity-80 transition-opacity"
                        >RSS</a
                    >. In my free time I watch anime and read quite a bit —
                    check out my <a
                        href="/media"
                        class="inline-flex items-center px-1.5 py-0.5 rounded bg-violet-100 text-violet-700 dark:bg-violet-950 dark:text-violet-300 text-xs font-medium hover:opacity-80 transition-opacity"
                        >media log</a
                    >.
                </p>
            </div>
        </div>
    </section>

    <hr class="border-border mb-10" />

    <!-- Latest Writing -->
    <section class="mb-10">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-basundergra tracking-tight">
                Latest writing
            </h2>
            <a
                href="/blog"
                class="text-xs text-muted-foreground hover:text-foreground transition"
            >
                View all →
            </a>
        </div>
        <div class="space-y-3">
            {
                latestPosts.map((post) => (
                    <a
                        href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}
                        class="flex justify-between items-start gap-4 rounded-lg border-2 border-border px-4 py-3 hover:bg-accent transition group"
                    >
                        <div>
                            <p class="text-sm font-medium group-hover:text-foreground">
                                {post.data.title}
                            </p>
                            <p class="text-xs text-muted-foreground mt-0.5 line-clamp-1">
                                {post.data.description}
                            </p>
                        </div>
                        <time class="text-xs text-muted-foreground whitespace-nowrap shrink-0 mt-0.5">
                            {new Date(post.data.pubDate).toLocaleDateString(
                                "en-US",
                                {
                                    month: "short",
                                    day: "numeric",
                                    year: "numeric",
                                },
                            )}
                        </time>
                    </a>
                ))
            }
        </div>
    </section>

    <hr class="border-border mb-10" />

    <!-- Projects -->
    <section class="mb-10">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold tracking-tight">Projects</h2>
            <a
                href="/projects"
                class="text-xs text-muted-foreground hover:text-foreground transition"
            >
                View all →
            </a>
        </div>
        <div class="space-y-3">
            {
                projects.map((project) => (
                    <a
                        href={project.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-start justify-between gap-4 rounded-lg border-2 border-border px-4 py-3 hover:bg-accent transition group"
                    >
                        <div>
                            <p class="text-sm font-medium">{project.title}</p>
                            <p class="text-xs text-muted-foreground mt-0.5">
                                {project.details}
                            </p>
                            <div class="flex flex-wrap gap-1.5 mt-2">
                                {project.tags.map((tag) => (
                                    <span class="px-1.5 py-0.5 text-xs rounded bg-muted text-muted-foreground">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                        <span class="text-muted-foreground text-xs shrink-0 mt-0.5 opacity-60">
                            ↗
                        </span>
                    </a>
                ))
            }
        </div>
    </section>

    <hr class="border-border mb-10" />

    
    <p class="text-xs text-muted-foreground">
        <a
            href="https://farhan291.github.io/profile/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-foreground transition-colors opacity-60 hover:opacity-100"
        >
            view archived version →
        </a>
    </p>
</Layout>
