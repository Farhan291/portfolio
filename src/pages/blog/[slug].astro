---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { render } from "astro:content";

export async function getStaticPaths() {
    const posts = (await getCollection("blog")).sort(
        (a, b) => new Date(a.data.pubDate).getTime() - new Date(b.data.pubDate).getTime()
    );
    return posts.map((post: CollectionEntry<"blog">, index) => ({
        params: { slug: post.id.replace(/\.mdx?$/, "") },
        props: { 
            post,
            prevPost: index > 0 ? posts[index - 1] : null,
            nextPost: index < posts.length - 1 ? posts[index + 1] : null,
        },
    }));
}

interface Props {
    post: CollectionEntry<"blog">;
    prevPost: CollectionEntry<"blog"> | null;
    nextPost: CollectionEntry<"blog"> | null;
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

// Series logic
const allPostsForSeries = await getCollection("blog");
let seriesPosts: CollectionEntry<"blog">[] = [];
const match = post.id.match(/^(.+?)[_-]\d+(\.mdx?)?$/);
if (match) {
    const prefix = match[1];
    seriesPosts = allPostsForSeries.filter((p) => {
        const pMatch = p.id.match(/^(.+?)[_-]\d+(\.mdx?)?$/);
        return pMatch && pMatch[1] === prefix;
    }).sort((a, b) => a.id.localeCompare(b.id));
}
if (seriesPosts.length <= 1) {
    seriesPosts = [];
}

const postSlug = post.id.replace(/\.mdx?$/, "");
const postURL = new URL(`/blog/${postSlug}`, Astro.site).href;
const postImage = post.data.cover
    ? (post.data.cover.startsWith("http") ? post.data.cover : new URL(post.data.cover, Astro.site).href)
    : "https://avatars.githubusercontent.com/farhan291";

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    image: postImage,
    datePublished: post.data.pubDate,
    url: postURL,
    author: {
        "@type": "Person",
        name: "Farhan",
        url: "https://ifarhan.tech/about",
    },
    publisher: {
        "@type": "Person",
        name: "Farhan",
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": postURL,
    },
    keywords: post.data.tags?.join(", "),
};
---

<Layout
    title={`${post.data.title} | farhan`}
    description={post.data.description}
    image={postImage}
    type="article"
    pubDate={post.data.pubDate}
    tags={post.data.tags}
    jsonLd={jsonLd}
>
    <div class="relative">
        <meta charset="UTF-8" />
        <aside class="hidden xl:block fixed left-6 top-24 w-64">
            <p class="mb-4 text-sm font-semibold uppercase opacity-60">
                Table of Contents
            </p>
            <ul class="space-y-2 border-l border-border pl-4">
                {
                    headings.map((heading) => (
                        <li class={heading.depth > 2 ? "ml-4" : ""}>
                            <a
                                href={`#${heading.slug}`}
                                class="block text-sm font-mono
                                 text-muted-foreground
                                 hover:text-foreground
                                 transition-colors"
                            >
                                {heading.text}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </aside>
        
        <article class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-3xl font-bold">{post.data.title}</h1>
            <time class="block mt-1 text-sm opacity-60">
                {post.data.pubDate}
            </time>
            {post.data.tags && (
                <div class="flex flex-wrap gap-1.5 mt-2">
                    {post.data.tags.map((tag: string) => (
                        <a
                            href={`/blog?tag=${tag}`}
                            class="border border-border px-1.5 py-0.5 text-xs rounded text-muted-foreground hover:bg-accent transition"
                        >
                            {tag}
                        </a>
                    ))}
                </div>
            )}
            <div class="prose dark:prose-invert max-w-none pt-6">
                {seriesPosts.length > 0 && (
                    <>
                        <p>{post.data.description} The table of contents:</p>
                        <ol>
                            {seriesPosts.map((p) => (
                                <li>
                                    {p.id === post.id ? (
                                        <strong>{p.data.title}</strong>
                                    ) : (
                                        <a href={`/blog/${p.id.replace(/\.mdx?$/, "")}`}>{p.data.title}</a>
                                    )}
                                </li>
                            ))}
                        </ol>
                        <hr />
                    </>
                )}
                <Content />
            </div>

            <!-- RSS and other channels -->
            <div class="mt-16 mb-8 border-l-4 border-red-500 bg-gray-100 dark:bg-gray-800 p-8 text-center flex flex-col items-center justify-center">
                <p class="text-gray-500 dark:text-gray-400 mb-6">Welcome to my other publishing channels</p>
                <a href="/rss.xml" class="flex flex-col items-center justify-center text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
                    <span>RSS</span>
                </a>
            </div>

            <!-- Tags -->
            {post.data.tags && (
                <div class="flex justify-center gap-4 mb-8">
                    {post.data.tags.map((tag: string) => (
                        <a
                            href={`/blog?tag=${tag}`}
                            class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 border-b border-gray-400 pb-0.5"
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            )}

            <!-- Post Navigation -->
            <hr class="border-border mb-6" />
            <div class="flex justify-between items-center text-sm">
                <div>
                    {prevPost && (
                        <a href={`/blog/${prevPost.id.replace(/\.mdx?$/, "")}`} class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 flex items-center gap-2">
                            <span>&lt;</span> {prevPost.data.title}
                        </a>
                    )}
                </div>
                <div>
                    {nextPost && (
                        <a href={`/blog/${nextPost.id.replace(/\.mdx?$/, "")}`} class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 flex items-center gap-2">
                            {nextPost.data.title} <span>&gt;</span>
                        </a>
                    )}
                </div>
            </div>
        </article>
    </div>
</Layout>

<style is:global>
    /* Better mobile code block handling */
    .prose pre {
        @apply overflow-x-auto;
        max-width: 100%;
    }

    .prose pre.astro-code {
        background-color: #f3f4f6 !important;
        border-color: #d1d5db;
    }
    
    .prose code {
        @apply break-words;
    }
    
    /* Ensure code blocks don't break layout on mobile */
    @media (max-width: 640px) {
        .prose pre {
            margin-left: -1rem;
            margin-right: -1rem;
            border-radius: 0;
        }
    }

    /* Center LaTeX display equations */
    .prose .katex-display {
        text-align: center;
        margin: 1.5rem 0;
    }
    
    .prose mjx-container[display="true"] {
        text-align: center;
        margin: 1.5rem 0;
    }
</style>
