    type="website"
    jsonLd={{
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Farhan",
        url: "https://ifarhan.tech/about",
        sameAs: [
            "https://github.com/farhan291",
        ],
        jobTitle: "CS Student",
        affiliation: "RIT Bangalore",
    }}
>
    <article class="prose dark:prose-invert text-foreground max-w-none p-4">
        <AboutContent />
    </article>
</Layout>
